# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/lorvault?schema=public"

# JWT (generate a secure secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))")
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Email (Resend - https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# App
APP_URL="http://localhost:3000"
FRONTEND_URL="exp://localhost:8081"
NODE_ENV="development"

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# File Storage (Supabase Storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_BUCKET="lors"

# Max file size in bytes (10MB)
MAX_FILE_SIZE=10485760

# Super Admin (created on first seed)
SUPER_ADMIN_EMAIL="admin@lorvault.app"
SUPER_ADMIN_PASSWORD="changeme123"
