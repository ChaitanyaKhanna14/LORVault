# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/lorvault?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# SendGrid (optional for MVP)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@lorvault.app"

# App
APP_URL="http://localhost:3000"
FRONTEND_URL="exp://localhost:8081"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Super Admin (created on first seed)
SUPER_ADMIN_EMAIL="admin@lorvault.app"
SUPER_ADMIN_PASSWORD="changeme123"
